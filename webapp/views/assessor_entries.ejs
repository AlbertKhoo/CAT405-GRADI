<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assessor Dashboard - GRADI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">
    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <span
                        class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500">GRADI</span>
                    <span
                        class="ml-4 px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full border border-emerald-100">Assessor
                        Dashboard</span>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-sm font-medium text-slate-600 bg-slate-50 px-4 py-2 rounded-lg">Role: <span
                            class="text-slate-900 font-bold">Assessor</span></div>
                    <a href="/"
                        class="text-slate-500 hover:text-red-500 font-medium text-sm transition-colors flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17 16l4-4m0 0l-4-4m4 4H7"></path>
                        </svg>
                        Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full space-y-8">

        <div class="flex items-center gap-4">
            <a href="/assessor" class="bg-white border border-slate-200 text-slate-500 hover:text-emerald-600 p-2 rounded-xl transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            </a>
            <div>
                <h1 class="text-3xl font-bold text-slate-900">Student Logbook Submissions</h1>
            <p class="text-slate-500 mt-2">Review submissions, check AI-generated insights, and provide final formal
                grades.</p>
        </div>

        <!-- Filter/Stats Row -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
                <p class="text-sm font-medium text-slate-500">Total Entries</p>
                <p class="text-3xl font-bold text-slate-900 mt-1">
                    <%= entries.length %>
                </p>
            </div>
            <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
                <p class="text-sm font-medium text-slate-500">Pending Review</p>
                <p class="text-3xl font-bold text-amber-500 mt-1">
                    <%= entries.filter(e=> !e.assessor_grade).length %>
                </p>
            </div>
            <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
                <p class="text-sm font-medium text-slate-500">Average AI Score</p>
                <p class="text-3xl font-bold text-emerald-600 mt-1">
                    <% const scored=entries.filter(e=> e.ai_score);
                        const avg = scored.length ? scored.reduce((sum, e) => sum + e.ai_score, 0) / scored.length : 0;
                        %>
                        <%= avg.toFixed(1) %>
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
            <% if(entries.length===0) { %>
                <div class="text-center py-16 bg-white border border-slate-200 rounded-2xl">
                    <p class="text-slate-500 text-lg">No entries found.</p>
                </div>
                <% } else { %>
                    <% entries.forEach(entry=> { %>
                        <div
                            class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col md:flex-row gap-6 transition-all hover:shadow-md">

                            <!-- Left Info -->
                            <div class="flex-grow">
                                <div class="flex items-center gap-3 mb-2">
                                    <h3 class="font-bold text-slate-900 text-lg">
                                        <%= entry.student_name %> (@<%= entry.username %>)
                                    </h3>
                                    <span class="bg-slate-100 text-slate-600 text-xs px-2 py-1 rounded font-medium">Proj
                                        ID: <%= entry.project_id %></span>
                                </div>

                                <div class="flex items-center gap-3 text-sm text-slate-500 font-medium mb-4">
                                    <span class="flex items-center gap-1">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                                            </path>
                                        </svg>
                                        <%= entry.logdate %>
                                    </span>
                                    <span>&bull;</span>
                                    <span class="flex items-center gap-1">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        <%= entry.loghours %> hrs (<%= entry.logstarthour %> - <%= entry.logendhour %>)
                                    </span>
                                </div>

                                <div
                                    class="bg-slate-50 border border-slate-100 p-4 rounded-xl text-sm text-slate-700 leading-relaxed prose max-w-none">
                                    <%- entry.lognotes %>
                                </div>

                                <% if(entry.ai_feedback) { %>
                                    <div class="mt-4 bg-indigo-50/50 border border-indigo-100 rounded-xl p-4">
                                        <p class="text-xs font-bold text-indigo-800 uppercase tracking-wider mb-1">AI
                                            Generated Feedback</p>
                                        <p class="text-indigo-900 text-sm font-medium italic">
                                            <%= entry.ai_feedback %>
                                        </p>
                                    </div>
                                    <% } %>
                            </div>

                            <!-- Right Scoring / Grading Pane -->
                            <div
                                class="md:w-64 flex-shrink-0 border-t md:border-t-0 md:border-l border-slate-100 pt-4 md:pt-0 md:pl-6 flex flex-col justify-between">
                                <div>
                                    <div class="mb-5 bg-slate-50 rounded-xl p-4 border border-slate-100 text-center">
                                        <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">AI
                                            Predicted Score</p>
                                        <div
                                            class="text-3xl font-black <%= (entry.ai_score >= 8) ? 'text-emerald-600' : (entry.ai_score >= 5 ? 'text-blue-600' : 'text-slate-600') %>">
                                            <%= entry.ai_score || '-' %><span
                                                    class="text-lg font-bold text-slate-400">/10</span>
                                        </div>
                                    </div>

                                    <% if(entry.assessor_grade) { %>
                                        <div
                                            class="bg-emerald-50 text-emerald-800 rounded-xl p-4 border border-emerald-200 text-center mb-4">
                                            <p class="text-xs font-bold uppercase tracking-wide mb-1 text-emerald-600">
                                                Final Grade</p>
                                            <div class="text-3xl font-black text-emerald-700">
                                                <%= entry.assessor_grade %><span
                                                        class="text-lg font-bold text-emerald-500">/10</span>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>

                                <!-- Grading Form -->
                                <form action="/assessor/grade" method="POST" class="mt-auto">
                                    <input type="hidden" name="entry_id" value="<%= entry.id %>">
                                    <div>
                                        <label
                                            class="block text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">
                                            <%= entry.assessor_grade ? 'Update Grade' : 'Assign Formal Grade' %>
                                        </label>
                                        <div class="flex items-center gap-2">
                                            <input type="number" name="assessor_grade" min="0" max="10" step="1"
                                                required value="<%= entry.assessor_grade || entry.ai_score || '' %>"
                                                class="w-20 rounded-lg border-slate-200 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-center font-bold text-lg p-2 outline-none border focus:bg-white bg-slate-50 transition-colors">
                                            <button type="submit"
                                                class="flex-grow bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-3 rounded-lg shadow-sm transition-colors text-sm active:scale-[0.98]">
                                                <%= entry.assessor_grade ? 'Update' : 'Confirm' %>
                                            </button>
                                        </div>
                                    </div>
                                </form>

                            </div>

                        </div>
                        <% }) %>
                            <% } %>
        </div>
    </main>
</body>

</html>