<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GRADI - Login</title>
    <!-- Use Tailwind CSS for modern aesthetics -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased overflow-x-hidden">
    <div class="min-h-screen flex flex-col items-center justify-center relative">
        <!-- Background accents -->
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4MCIgaGVpZ2h0PSI4MCI+PGNpcmNsZSBjeD0iMTkiIGN5PSIxOSIgcj0iMiIgZmlsbD0iI2U1ZTdlYiIvPjwvc3ZnPg==')] opacity-60 pointer-events-none"></div>

        <div class="relative z-10 text-center mb-10">
            <h1 class="text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-400 mb-4 drop-shadow-md">GRADI</h1>
            <p class="text-xl text-slate-500 max-w-lg mx-auto font-medium">Automated Feedback & Scoring for Practicum Logbooks</p>
        </div>

        <div class="relative z-10 w-full max-w-md">
            <div class="bg-white/80 backdrop-blur-xl rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 p-8 transition-all hover:shadow-2xl hover:shadow-slate-200 duration-500">
                <div class="mb-8 text-center">
                    <h2 class="text-2xl font-bold text-slate-800">Sign In</h2>
                    <p class="text-sm text-slate-500 mt-1">Select your role to continue</p>
                </div>
                
                <form action="/login" method="POST" class="space-y-4 pt-2">
                    <% if (typeof error !== 'undefined') { %>
                        <div class="bg-red-50 border border-red-200 text-red-600 text-sm p-3 rounded-xl mb-4 text-center font-medium">
                            <%= error %>
                        </div>
                    <% } %>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                        <input type="email" name="username" required
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-2.5 outline-none transition-all placeholder:text-slate-400 bg-slate-50 focus:bg-white border"
                            placeholder="e.g. alice@student.edu">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                        <input type="password" name="password" required
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-2.5 outline-none transition-all bg-slate-50 focus:bg-white border"
                            placeholder="••••••••">
                    </div>
                    <button type="submit"
                        class="w-full flex justify-center py-3 mt-4 text-white bg-blue-600 hover:bg-blue-700 rounded-xl text-sm font-semibold transition-all shadow-sm hover:shadow active:scale-[0.98]">
                        Sign In
                    </button>
                    
                </form>
            </div>
            <p class="text-center text-sm text-slate-400 mt-8 font-medium">Developed for CAT405 Major Project</p>
        </div>
    </div>
</body>
</html>
