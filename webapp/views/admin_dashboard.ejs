<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - GRADI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">
    <!-- Navbar -->
    <nav class="bg-slate-900 border-b border-slate-800 sticky top-0 z-50 shadow-md text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <span class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-400">GRADI</span>
                    <span class="ml-4 px-3 py-1 bg-violet-900/50 text-violet-300 text-xs font-semibold rounded-full border border-violet-800">Admin Control Center</span>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-sm font-medium text-slate-300 bg-slate-800 px-4 py-2 rounded-lg border border-slate-700">
                        Hello, <span class="text-white font-bold"><%= user.name %></span>
                    </div>
                    <a href="/" class="text-slate-400 hover:text-red-400 font-medium text-sm transition-colors flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7"></path>
                        </svg>
                        Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Container -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full space-y-8">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-slate-200 pb-6">
            <div>
                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">System Configuration & Management</h1>
                <p class="text-slate-500 mt-2 text-sm md:text-base">Configure machine learning models, manage students and assessors, and update the rubric system.</p>
            </div>
            
            <!-- Tab Buttons -->
            <div class="flex space-x-1 bg-slate-200/60 p-1.5 rounded-xl mt-4 md:mt-0 border border-slate-200/80 self-start md:self-center shadow-inner">
                <button onclick="switchTab('users')" id="btn-users" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all">Users</button>
                <button onclick="switchTab('models')" id="btn-models" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all">ML Model & RMSE</button>
                <button onclick="switchTab('rubrics')" id="btn-rubrics" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all">Rubrics</button>
            </div>
        </div>

        <!-- TAB: USERS -->
        <div id="tab-users" class="tab-content space-y-6">
            <div class="flex justify-between items-center">
                <h2 class="text-2xl font-bold text-slate-800">User Management</h2>
                <button onclick="openModal('addUserModal')" class="bg-violet-600 hover:bg-violet-700 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md hover:shadow-lg flex items-center gap-1.5 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Register User
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Students Table -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="p-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                        <h3 class="font-bold text-slate-800 flex items-center gap-2">
                            <span class="w-2.5 h-2.5 bg-blue-500 rounded-full"></span>
                            Students (<%= students.length %>)
                        </h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50/70 text-slate-500 uppercase text-xs font-semibold tracking-wider">
                                <tr>
                                    <th class="px-6 py-3.5 text-left">Name</th>
                                    <th class="px-6 py-3.5 text-left">Email / Username</th>
                                    <th class="px-6 py-3.5 text-left">Project ID</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 text-sm text-slate-600">
                                <% if(students.length === 0) { %>
                                    <tr>
                                        <td colspan="3" class="px-6 py-8 text-center text-slate-400">No students registered yet.</td>
                                    </tr>
                                <% } else { %>
                                    <% students.forEach(s => { %>
                                        <tr class="hover:bg-slate-50/50 transition-colors">
                                            <td class="px-6 py-4 font-bold text-slate-900"><%= s.name %></td>
                                            <td class="px-6 py-4"><%= s.username %></td>
                                            <td class="px-6 py-4">
                                                <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full border border-blue-100">
                                                    <%= s.project_id || 'None' %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Assessors Table -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="p-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                        <h3 class="font-bold text-slate-800 flex items-center gap-2">
                            <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
                            Assessors (<%= assessors.length %>)
                        </h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50/70 text-slate-500 uppercase text-xs font-semibold tracking-wider">
                                <tr>
                                    <th class="px-6 py-3.5 text-left">Name</th>
                                    <th class="px-6 py-3.5 text-left">Email / Username</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 text-sm text-slate-600">
                                <% if(assessors.length === 0) { %>
                                    <tr>
                                        <td colspan="2" class="px-6 py-8 text-center text-slate-400">No assessors registered yet.</td>
                                    </tr>
                                <% } else { %>
                                    <% assessors.forEach(a => { %>
                                        <tr class="hover:bg-slate-50/50 transition-colors">
                                            <td class="px-6 py-4 font-bold text-slate-900"><%= a.name %></td>
                                            <td class="px-6 py-4"><%= a.username %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: MODELS -->
        <div id="tab-models" class="tab-content space-y-6">
            <h2 class="text-2xl font-bold text-slate-800">Machine Learning Config & Evaluation</h2>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left: Model Metrics / RMSE Display -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- RMSE Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Card 1 -->
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                            <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Random Forest</div>
                            <div class="text-3xl font-black text-violet-600"><%= modelSetup.rf_rmse ? modelSetup.rf_rmse.toFixed(4) : 'N/A' %></div>
                            <p class="text-xs text-slate-500 mt-2 font-medium">Root Mean Square Error</p>
                        </div>
                        <!-- Card 2 -->
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                            <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Gradient Boosting</div>
                            <div class="text-3xl font-black text-indigo-600"><%= modelSetup.gb_rmse ? modelSetup.gb_rmse.toFixed(4) : 'N/A' %></div>
                            <p class="text-xs text-slate-500 mt-2 font-medium">Root Mean Square Error</p>
                        </div>
                        <!-- Card 3 -->
                        <div class="bg-white p-6 rounded-2xl border-2 border-violet-500/20 bg-gradient-to-br from-white to-violet-50/20 relative overflow-hidden">
                            <div class="absolute -right-4 -bottom-4 text-violet-100 opacity-50">
                                <svg class="w-20 h-20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.75z"/></svg>
                            </div>
                            <div class="relative z-10">
                                <div class="text-xs font-bold text-violet-500 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                                    <span class="flex h-2 w-2 relative">
                                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet-400 opacity-75"></span>
                                      <span class="relative inline-flex rounded-full h-2 w-2 bg-violet-500"></span>
                                    </span>
                                    VotingRegressor (Ensemble)
                                </div>
                                <div class="text-3xl font-black text-slate-900"><%= modelSetup.ensemble_rmse ? modelSetup.ensemble_rmse.toFixed(4) : 'N/A' %></div>
                                <p class="text-xs text-slate-500 mt-2 font-medium">Production Inference RMSE</p>
                            </div>
                        </div>
                    </div>

                    <!-- Retraining Controller card -->
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-6">
                        <div class="flex justify-between items-center">
                            <div>
                                <h3 class="font-bold text-slate-800 text-lg">Model Retraining Status</h3>
                                <p class="text-sm text-slate-500">Trigger model training to recalculate RMSE and build the latest predictor.</p>
                            </div>
                            <div class="text-right">
                                <span class="text-xs text-slate-400 block uppercase font-bold">Last Trained</span>
                                <span class="text-sm text-slate-700 font-semibold" id="last-trained-time"><%= modelSetup.last_trained || 'Never' %></span>
                            </div>
                        </div>

                        <!-- Training Status Indicator Banner -->
                        <div id="training-banner" class="bg-slate-50 border border-slate-100 rounded-xl p-4 flex items-center justify-between transition-colors">
                            <div class="flex items-center space-x-3">
                                <div id="status-spinner" class="hidden">
                                    <svg class="animate-spin h-5 w-5 text-violet-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                </div>
                                <div id="status-icon-dot" class="h-3 w-3 bg-slate-400 rounded-full"></div>
                                <span id="status-message" class="text-sm font-semibold text-slate-600">Model pipeline is idle.</span>
                            </div>
                            
                            <button id="btn-retrain" onclick="startRetraining()" class="bg-violet-600 hover:bg-violet-700 disabled:bg-slate-300 disabled:cursor-not-allowed text-white px-5 py-2 rounded-lg text-sm font-semibold transition-all shadow cursor-pointer">
                                Run Retraining
                            </button>
                        </div>
                    </div>

                    <!-- AI Feedback Prompt Editor -->
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                            <h3 class="font-bold text-slate-800 text-lg">AI Feedback Prompt Template</h3>
                        </div>
                        <form action="/admin/prompt/update" method="POST" class="p-6 space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Prompt Template</label>
                                <textarea name="feedback_prompt" rows="10" required
                                    class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-3 outline-none border focus:bg-white bg-slate-50 transition-colors font-mono text-xs leading-relaxed resize-y"><%= feedbackPrompt %></textarea>
                            </div>
                            
                            <!-- Prompt Guidelines -->
                            <div class="bg-violet-50 border border-violet-100 rounded-xl p-4 flex gap-3">
                                <div class="flex-shrink-0 text-violet-500 mt-0.5">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                                <div class="text-xs text-violet-800 space-y-1">
                                    <p class="font-bold">Required Placeholders:</p>
                                    <p>Your prompt template must include the following placeholders to dynamically merge student entries:</p>
                                    <ul class="list-disc pl-4 space-y-0.5">
                                        <li><code class="bg-white px-1 py-0.5 rounded font-bold">{logNotes}</code>: Swapped with the student's lognotes / reflection.</li>
                                        <li><code class="bg-white px-1 py-0.5 rounded font-bold">{score}</code>: Swapped with the AI predicted score (e.g. 7.5).</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="flex justify-end">
                                <button type="submit" class="px-6 py-2.5 text-white bg-violet-600 hover:bg-violet-700 rounded-xl text-sm font-semibold transition-all shadow hover:shadow-md cursor-pointer">
                                    Save Prompt Template
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Right: Model Hyperparameter Editing -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden sticky top-24">
                        <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                            <h3 class="font-bold text-slate-800 text-lg">Hyperparameter Tuning</h3>
                        </div>
                        <form action="/admin/model/update" method="POST" class="p-6 space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Random Forest Estimators</label>
                                <input type="number" name="rf_estimators" required value="<%= modelSetup.rf_estimators %>" min="10" max="500"
                                    class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                                <span class="text-xs text-slate-400 mt-1 block">Number of trees in the Random Forest. (Default: 100)</span>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">Gradient Boosting Estimators</label>
                                <input type="number" name="gb_estimators" required value="<%= modelSetup.gb_estimators %>" min="10" max="500"
                                    class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                                <span class="text-xs text-slate-400 mt-1 block">Number of boosting stages. (Default: 100)</span>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">TF-IDF Max Features</label>
                                <input type="number" name="tfidf_features" required value="<%= modelSetup.tfidf_features %>" min="100" max="5000"
                                    class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                                <span class="text-xs text-slate-400 mt-1 block">Max size of the vocabulary built by TF-IDF. (Default: 1000)</span>
                            </div>

                            <button type="submit" class="w-full flex justify-center py-2.5 text-white bg-violet-600 hover:bg-violet-700 rounded-xl text-sm font-semibold transition-all shadow hover:shadow-md active:scale-[0.98] cursor-pointer">
                                Save Setup Parameters
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: RUBRICS -->
        <div id="tab-rubrics" class="tab-content space-y-6">
            <div class="flex justify-between items-center">
                <h2 class="text-2xl font-bold text-slate-800">Logbook Assessment Rubrics</h2>
                <button onclick="openModal('addRubricModal')" class="bg-violet-600 hover:bg-violet-700 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md hover:shadow-lg flex items-center gap-1.5 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Add Criteria
                </button>
            </div>

            <!-- Rubrics Table -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">Active Rubric Criteria Rows</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50/70 text-slate-500 uppercase text-xs font-semibold tracking-wider">
                            <tr>
                                <th class="px-6 py-3.5 text-left">Factor</th>
                                <th class="px-6 py-3.5 text-left">Code</th>
                                <th class="px-6 py-3.5 text-left">Rubric Element</th>
                                <th class="px-6 py-3.5 text-left">Weightage (%)</th>
                                <th class="px-6 py-3.5 text-left">Multiplier</th>
                                <th class="px-6 py-3.5 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 text-sm text-slate-600">
                            <% if(rubrics.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-slate-400">No rubrics created yet.</td>
                                </tr>
                            <% } else { %>
                                <% rubrics.forEach(r => { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-6 py-4 font-semibold text-slate-900"><%= r.rubric_factor %></td>
                                        <td class="px-6 py-4 font-mono"><%= r.rubric_code %></td>
                                        <td class="px-6 py-4 font-medium"><%= r.element %></td>
                                        <td class="px-6 py-4"><%= r.element_weightage %>%</td>
                                        <td class="px-6 py-4 font-semibold text-slate-900"><%= r.element_multiplier %></td>
                                        <td class="px-6 py-4 text-center">
                                            <div class="flex items-center justify-center space-x-2">
                                                <button onclick="openEditRubricModal(<%= JSON.stringify(r) %>)" 
                                                    class="text-xs bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 px-2.5 py-1.5 rounded-lg transition-colors cursor-pointer">
                                                    Edit
                                                </button>
                                                <form action="/admin/rubric/delete/<%= r.id %>" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this rubric?');">
                                                    <button type="submit" 
                                                        class="text-xs bg-red-50 hover:bg-red-100 border border-red-200 text-red-600 px-2.5 py-1.5 rounded-lg transition-colors cursor-pointer">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL: ADD USER -->
    <div id="addUserModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden border border-slate-100 mx-4">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                <h3 class="text-xl font-bold text-slate-800">Register System User</h3>
                <button onclick="closeModal('addUserModal')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/admin/user/add" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">User Role</label>
                    <select name="role" id="userRoleSelect" onchange="toggleProjectIDField()"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                        <option value="student">Student</option>
                        <option value="assessor">Assessor</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Full Name</label>
                    <input type="text" name="name" required placeholder="e.g. John Doe"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Email / Username</label>
                    <input type="email" name="username" required placeholder="e.g. john@student.edu"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Password</label>
                    <input type="password" name="password" required placeholder="••••••••"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <!-- Student Specific: Project ID -->
                <div id="projectIdField">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Project ID Mapping</label>
                    <input type="number" name="project_id" placeholder="e.g. 542"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                    <span class="text-xs text-slate-400 mt-1 block">Links the student to a specific logbook dataset Project ID.</span>
                </div>

                <div class="pt-4 flex space-x-3">
                    <button type="button" onclick="closeModal('addUserModal')" class="w-1/2 py-3 bg-slate-100 hover:bg-slate-200 rounded-xl text-sm font-semibold text-slate-600 transition-colors cursor-pointer">Cancel</button>
                    <button type="submit" class="w-1/2 py-3 bg-violet-600 hover:bg-violet-700 text-white rounded-xl text-sm font-semibold transition-all shadow hover:shadow-md cursor-pointer">Create User</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: ADD RUBRIC -->
    <div id="addRubricModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden border border-slate-100 mx-4">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                <h3 class="text-xl font-bold text-slate-800">Add Rubric Criteria</h3>
                <button onclick="closeModal('addRubricModal')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/admin/rubric/add" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Rubric Factor</label>
                    <input type="text" name="rubric_factor" required placeholder="e.g. LB"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Rubric Code</label>
                    <input type="text" name="rubric_code" required placeholder="e.g. LB1"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Element Name</label>
                    <input type="text" name="element" required placeholder="e.g. Content reflection"
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Weightage (%)</label>
                        <input type="number" name="element_weightage" step="any" required placeholder="e.g. 50"
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Multiplier</label>
                        <input type="number" name="element_multiplier" step="any" required placeholder="e.g. 5.0"
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                    </div>
                </div>

                <div class="pt-4 flex space-x-3">
                    <button type="button" onclick="closeModal('addRubricModal')" class="w-1/2 py-3 bg-slate-100 hover:bg-slate-200 rounded-xl text-sm font-semibold text-slate-600 transition-colors cursor-pointer">Cancel</button>
                    <button type="submit" class="w-1/2 py-3 bg-violet-600 hover:bg-violet-700 text-white rounded-xl text-sm font-semibold transition-all shadow hover:shadow-md cursor-pointer">Create Criteria</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: EDIT RUBRIC -->
    <div id="editRubricModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden border border-slate-100 mx-4">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                <h3 class="text-xl font-bold text-slate-800">Edit Rubric Criteria</h3>
                <button onclick="closeModal('editRubricModal')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="editRubricForm" action="" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Rubric Factor</label>
                    <input type="text" name="rubric_factor" id="editRubricFactor" required
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Rubric Code</label>
                    <input type="text" name="rubric_code" id="editRubricCode" required
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Element Name</label>
                    <input type="text" name="element" id="editRubricElement" required
                        class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Weightage (%)</label>
                        <input type="number" name="element_weightage" id="editRubricWeightage" step="any" required
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Multiplier</label>
                        <input type="number" name="element_multiplier" id="editRubricMultiplier" step="any" required
                            class="w-full rounded-xl border-slate-200 shadow-sm focus:border-violet-500 focus:ring-violet-500 sm:text-sm px-4 py-2.5 outline-none border focus:bg-white bg-slate-50 transition-colors">
                    </div>
                </div>

                <div class="pt-4 flex space-x-3">
                    <button type="button" onclick="closeModal('editRubricModal')" class="w-1/2 py-3 bg-slate-100 hover:bg-slate-200 rounded-xl text-sm font-semibold text-slate-600 transition-colors cursor-pointer">Cancel</button>
                    <button type="submit" class="w-1/2 py-3 bg-violet-600 hover:bg-violet-700 text-white rounded-xl text-sm font-semibold transition-all shadow hover:shadow-md cursor-pointer">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // Tab switching logic
        function switchTab(tabId) {
            // Hide all tab content
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            // Remove active styling from tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-white', 'text-violet-600', 'shadow-sm');
                btn.classList.add('text-slate-600');
            });

            // Show selected tab content
            document.getElementById('tab-' + tabId).classList.add('active');
            // Add active styling to clicked button
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.remove('text-slate-600');
            activeBtn.classList.add('bg-white', 'text-violet-600', 'shadow-sm');
            
            // Save tab preference to localStorage
            localStorage.setItem('adminActiveTab', tabId);
        }

        // Initialize active tab from localStorage or default to 'users'
        document.addEventListener('DOMContentLoaded', () => {
            const activeTab = localStorage.getItem('adminActiveTab') || 'users';
            switchTab(activeTab);
            
            // Start training monitor in case it was already running
            checkTrainingStatus(true);
        });

        // Modal triggers
        function openModal(modalId) {
            document.getElementById(modalId).classList.remove('hidden');
        }
        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
        }

        // Rubric Edit modal pre-filler
        function openEditRubricModal(rubric) {
            document.getElementById('editRubricForm').action = `/admin/rubric/update/${rubric.id}`;
            document.getElementById('editRubricFactor').value = rubric.rubric_factor;
            document.getElementById('editRubricCode').value = rubric.rubric_code;
            document.getElementById('editRubricElement').value = rubric.element;
            document.getElementById('editRubricWeightage').value = rubric.element_weightage;
            document.getElementById('editRubricMultiplier').value = rubric.element_multiplier;
            openModal('editRubricModal');
        }

        // Toggle Project ID input depending on role
        function toggleProjectIDField() {
            const role = document.getElementById('userRoleSelect').value;
            const projectField = document.getElementById('projectIdField');
            if (role === 'student') {
                projectField.style.display = 'block';
            } else {
                projectField.style.display = 'none';
            }
        }

        // Trigger retraining via AJAX
        function startRetraining() {
            const btn = document.getElementById('btn-retrain');
            btn.disabled = true;
            btn.innerText = 'Initializing...';
            
            updateStatusUI('training', 'Training process starting...');

            fetch('/admin/model/train', { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.status === 'started') {
                        checkTrainingStatus();
                    } else {
                        btn.disabled = false;
                        btn.innerText = 'Run Retraining';
                        updateStatusUI('error', 'Failed to start retraining.');
                    }
                })
                .catch(err => {
                    btn.disabled = false;
                    btn.innerText = 'Run Retraining';
                    updateStatusUI('error', 'Network error occurred.');
                });
        }

        // Check retraining status from backend
        let statusInterval = null;
        function checkTrainingStatus(isInitial = false) {
            fetch('/admin/model/train-status')
                .then(res => res.json())
                .then(data => {
                    updateStatusUI(data.status, data.error);
                    
                    if (data.status === 'training') {
                        document.getElementById('btn-retrain').disabled = true;
                        document.getElementById('btn-retrain').innerText = 'Retraining...';
                        
                        // Poll status every 2 seconds
                        if (!statusInterval) {
                            statusInterval = setInterval(() => checkTrainingStatus(), 2000);
                        }
                    } else {
                        if (statusInterval) {
                            clearInterval(statusInterval);
                            statusInterval = null;
                        }
                        document.getElementById('btn-retrain').disabled = false;
                        document.getElementById('btn-retrain').innerText = 'Run Retraining';
                        
                        // If it just finished training, reload page to fetch newly calculated RMSE
                        if (data.status === 'finished' && !isInitial) {
                            updateStatusUI('finished', 'Model successfully trained! Refreshing page...');
                            setTimeout(() => {
                                window.location.reload();
                            }, 1500);
                        }
                    }
                })
                .catch(err => {
                    console.error("Error monitoring train status:", err);
                });
        }

        // Update UI banner color & text
        function updateStatusUI(status, errorDetail) {
            const banner = document.getElementById('training-banner');
            const dot = document.getElementById('status-icon-dot');
            const spinner = document.getElementById('status-spinner');
            const msg = document.getElementById('status-message');

            // Reset classes
            banner.className = 'rounded-xl p-4 flex items-center justify-between transition-colors border ';
            dot.className = 'h-3 w-3 rounded-full ';
            spinner.classList.add('hidden');

            if (status === 'training') {
                banner.classList.add('bg-amber-50', 'border-amber-200');
                spinner.classList.remove('hidden');
                dot.classList.add('hidden');
                msg.innerText = 'Retraining models in the background... Please do not close this tab.';
                msg.className = 'text-sm font-semibold text-amber-700';
            } else if (status === 'finished') {
                banner.classList.add('bg-emerald-50', 'border-emerald-200');
                dot.classList.remove('hidden');
                dot.classList.add('bg-emerald-500');
                msg.innerText = errorDetail || 'Model successfully trained and deployed.';
                msg.className = 'text-sm font-semibold text-emerald-700';
            } else if (status === 'error') {
                banner.classList.add('bg-red-50', 'border-red-200');
                dot.classList.remove('hidden');
                dot.classList.add('bg-red-500');
                msg.innerText = errorDetail || 'Training failed. Check logs.';
                msg.className = 'text-sm font-semibold text-red-700';
            } else { // 'idle'
                banner.classList.add('bg-slate-50', 'border-slate-200');
                dot.classList.remove('hidden');
                dot.classList.add('bg-slate-400');
                msg.innerText = 'Model pipeline is idle.';
                msg.className = 'text-sm font-semibold text-slate-600';
            }
        }
    </script>
</body>
</html>
